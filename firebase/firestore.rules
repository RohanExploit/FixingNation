rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Auth helpers ────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ── Post creation validator ──────────────────────────────────────────────
    //
    // Validates the raw fields that Flutter supplies on post creation.
    // Status must be 'under_review' — the app no longer uses PENDING_MODERATION.
    // The Cloudflare Worker (AI) path is disabled; all posts go directly to
    // under_review and are immediately visible in the city feed.

    function validPostCreate() {
      let d = request.resource.data;
      return d.authorId        == request.auth.uid
          && d.title           is string
          && d.title.size()    >  0
          && d.title.size()    <= 200
          && d.description     is string
          && d.description.size() > 0
          && d.description.size() <= 1000
          && d.status          == 'under_review'
          && d.upvotes         == 0
          && d.commentsCount   == 0;
    }

    // ── Collections ─────────────────────────────────────────────────────────

    match /users/{uid} {
      // Auth-gated: only signed-in users read profiles (H-6 fix)
      allow read:   if isSignedIn();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    match /posts/{postId} {
      // Anyone signed-in can read posts.
      // Unauthenticated users cannot scrape the feed.
      allow read: if isSignedIn();

      // Signed-in users may create posts with validated raw fields only.
      allow create: if isSignedIn() && validPostCreate();

      // Users may increment upvotes on their own or others' posts.
      // Only admins may change status / other fields.
      allow update: if isAdmin()
                    || (isSignedIn()
                        && request.resource.data.diff(resource.data).affectedKeys()
                            .hasOnly(['upvotes', 'updatedAt']));

      allow delete: if isAdmin();

      match /comments/{commentId} {
        allow read:   if isSignedIn();
        allow create: if isSignedIn()
                      && request.resource.data.authorId == request.auth.uid
                      && request.resource.data.text is string
                      && request.resource.data.text.size() > 0
                      && request.resource.data.text.size() <= 500;
        allow update, delete: if isAdmin();
      }
    }

    match /reports/{reportId} {
      allow create:               if isSignedIn();
      allow read, update, delete: if isAdmin();
    }

    match /authorities/{authorityId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // Deny all unmapped paths.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
